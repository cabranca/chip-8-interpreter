{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Debug",
            "type": "shell",
            "command": "cmake --build build/Debug --config Debug --target chip-8-interpreter --",
            "group": "build",
            "problemMatcher": ["$msCompile"],
            "detail": "Compila en modo Debug usando todos los cores."
        },
        {
            "label": "Build Release",
            "type": "shell",
            "command": "cmake --build build/Release --config Release --target chip-8-interpreter --",
            "group": "build",
            "problemMatcher": ["$msCompile"],
            "detail": "Compila en modo Release con optimizaciones activadas."
        },
        {
            "label": "Clean Debug",
            "type": "shell",
            "command": "cmake --build build/Debug --config Debug --target clean --",
            "group": "build",
            "problemMatcher": ["$msCompile"],
            "detail": "Limpia los artefactos de compilación Debug."
        },
        {
            "label": "Clean Release",
            "type": "shell",
            "command": "cmake --build build/Release --config Release --target clean --",
            "group": "build",
            "problemMatcher": ["$msCompile"],
            "detail": "Limpia los artefactos de compilación Release."
        }
    ]
}