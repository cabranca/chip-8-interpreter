{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Debug",
            "type": "shell",
            "command": "cd build/Debug && make chip-8-interpreter -j $(nproc)",
            "group": "build",
            "problemMatcher": ["$gcc"],
            "detail": "Configura y compila en modo Debug usando todos los cores."
        },
        {
            "label": "Build Release",
            "type": "shell",
            "command": "cd build/Release && make chip-8-interpreter -j $(nproc)",
            "group": "build",
            "problemMatcher": ["$gcc"],
            "detail": "Configura y compila en modo Release con optimizaciones activadas."
        },
        {
            "label": "Clean Debug",
            "type": "shell",
            "command": "cd build/Release && make clean chip-8-interpreter -j $(nproc)",
            "group": "build",
            "problemMatcher": ["$gcc"],
            "detail": "Limpia los artefactos de compilación Debug."
        },
        {
            "label": "Clean Release",
            "type": "shell",
            "command": "make -C build/Release clean",
            "group": "build",
            "problemMatcher": ["$gcc"],
            "detail": "Limpia los artefactos de compilación Release."
        }
    ]
}